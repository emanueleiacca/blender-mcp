.venv

# macOS
.DS_Store

# Local config secrets
src/blender_mcp/config.py

# Resolved MCP config (= per-user paths). Use Bible/.mcp.json.template as starting point.
Bible/.mcp.json

# Claude local/project metadata
Bible/.claude/

# Knowledge base build artifacts and raw source material
Bible/Bambu Wiki documentation/clusters.json
Bible/Blender for 3d print documentation/clusters.json
Bible/Scraping/
Bible/Research materials/

# Session logs — free-text personal notes (gitignored).
# Technical YAML logs in Bible/sessions/*.yaml are versioned for traceability;
# only the _private/ sidecar with personal notes is ignored.
Bible/sessions/_private/*
!Bible/sessions/_private/.gitkeep

# MoldboxerStudy folder:
# - decompiled bytecode + partial source of a commercial Blender add-on
#   are local-only study material — keep gitignored.
# - moldboxer_lite/ (clean-room reconstruction written by the user from
#   understanding of the public API) + .md docs (user's own analysis)
#   ARE original work and can be committed.
MoldboxerStudy/decompiled/
MoldboxerStudy/decompiled_py/
MoldboxerStudy/moldboxer_silicone/
MoldboxerStudy/portable_config/
MoldboxerStudy/mbx.ico
MoldboxerStudy/Moldboxer Guide*.txt
# Live-test artefacts produced during validation (large STLs + screenshots)
MoldboxerStudy/live_test_*.png
MoldboxerStudy/live_test_export/
