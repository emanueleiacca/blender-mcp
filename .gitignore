# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# macOS
.DS_Store

# Local config secrets
src/blender_mcp/config.py

# Resolved MCP config (= per-user paths). Use Bible/.mcp.json.template as starting point.
Bible/.mcp.json

# Claude local/project metadata
Bible/.claude/

# Knowledge base build artifacts and raw source material
Bible/Bambu Wiki documentation/clusters.json
Bible/Blender for 3d print documentation/clusters.json
Bible/Scraping/
Bible/Research materials/

# Session logs — free-text personal notes (gitignored).
# Technical YAML logs in Bible/sessions/*.yaml are versioned for traceability;
# only the _private/ sidecar with personal notes is ignored.
Bible/sessions/_private/*
!Bible/sessions/_private/.gitkeep
